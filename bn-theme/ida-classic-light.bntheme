        "graphBackgroundDarkColor":             "backgroundAlt",
        "graphBackgroundLightColor":            "background",
        "graphNodeDarkColor":                   "backgroundLight",
        "graphNodeLightColor":                  "white",
        "graphNodeOutlineColor":                "textSecondary",
        "graphNodeShadowColor":                 "backgroundAlt",
        "trueBranchColor":                      "trueGreen",
        "falseBranchColor":                     "falseRed",
